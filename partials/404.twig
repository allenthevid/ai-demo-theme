<section class="not-found relative bg-dark overflow-hidden">
	{# Orbital Rings Background #}
	<div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-30">
		<svg width="800" height="800" viewBox="0 0 800 800" fill="none" xmlns="http://www.w3.org/2000/svg">
			{# Outer Ring #}
			<ellipse cx="400" cy="400" rx="380" ry="380" stroke="url(#gradient1)" stroke-width="1" fill="none" opacity="0.3"/>
			{# Middle Ring #}
			<ellipse cx="400" cy="400" rx="280" ry="280" stroke="url(#gradient2)" stroke-width="1" fill="none" opacity="0.5"/>
			{# Inner Ring #}
			<ellipse cx="400" cy="400" rx="180" ry="180" stroke="url(#gradient3)" stroke-width="1" fill="none" opacity="0.7"/>
			
			{# Glowing Center Circle #}
			<circle cx="400" cy="400" r="8" fill="#00A17E" opacity="0.8">
				<animate attributeName="opacity" values="0.8;1;0.8" dur="2s" repeatCount="indefinite"/>
				<animate attributeName="r" values="8;12;8" dur="2s" repeatCount="indefinite"/>
			</circle>
			
			{# Gradients #}
			<defs>
				<radialGradient id="gradient1">
					<stop offset="0%" style="stop-color:#00A17E;stop-opacity:0.2" />
					<stop offset="100%" style="stop-color:#0073D8;stop-opacity:0.4" />
				</radialGradient>
				<radialGradient id="gradient2">
					<stop offset="0%" style="stop-color:#FF571D;stop-opacity:0.3" />
					<stop offset="100%" style="stop-color:#00A17E;stop-opacity:0.5" />
				</radialGradient>
				<radialGradient id="gradient3">
					<stop offset="0%" style="stop-color:#0073D8;stop-opacity:0.4" />
					<stop offset="100%" style="stop-color:#FF571D;stop-opacity:0.6" />
				</radialGradient>
			</defs>
		</svg>
	</div>

	{# Content #}
	<div class="container-lg relative z-10 py-[120px] lg:py-[180px]">
		<div class="max-w-[700px] mx-auto text-center">
			{# 404 Number #}
			<div class="mb-8">
				<span class="text-[120px] lg:text-[180px] font-bold leading-none bg-gradient-to-r from-[#00A17E] via-[#0073D8] to-[#FF571D] bg-clip-text text-transparent">
					404
				</span>
			</div>

			{# Heading #}
			{% include 'components/heading.twig' with {
				'value': nt_heading ?: 'Page Not Found',
				'type': 'h1',
				'class': 'text-white text-[32px] lg:text-[48px] font-bold mb-6'
			} %}

			{# Description #}
			<p class="text-white/80 text-lg lg:text-xl mb-10 max-w-[500px] mx-auto">
				The page you're looking for doesn't exist or has been moved. Let's get you back on track.
			</p>

			{# CTA Buttons #}
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
				{% include 'components/cta.twig' with {
					'cta': nt_cta ?: {'url': '/', 'title': 'Back to Home', 'target': '_self'},
					'class': 'btn-primary'
				} %}
				
				<a href="javascript:history.back()" class="btn btn-secondary">
					Go Back
				</a>
			</div>
		</div>
	</div>
</section>
