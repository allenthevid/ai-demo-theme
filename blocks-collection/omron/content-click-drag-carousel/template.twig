{# {{ function('dd', fields) }} #}
{% cache "block;" ~ post.id ~ ";" ~ block.id ~ ";" ~ post.modified_timestamp ~ ";" ~ cache_key %}

<section class="{{ block.slug }} bg-{{ fields.bg }} overflow-x-clip overflow-y-visible">
	{% if block.anchor %}
		<div class="section-anchor" id="{{ block.anchor ?? block.id }}"></div>
	{% endif %}

	{% set pt = fields.padding_top and fields.padding_top != "unset" ? fields.padding_top : "st-xxl" %}
	{% set pb = fields.padding_top and fields.padding_bottom != "unset" ? fields.padding_bottom : "sb-xxl" %}

	<div class="relative z-[2] overflow-hidden">
		<div class="container">
			<div class="{{ pt }} {{ pb }}">
				<div class="flex flex-col ~gap-[2.25rem]/[3rem]">
					<div class="w-full flex justify-between">
						<div class="md:flex-1 max-md:flex max-md:flex-col max-md:gap-[0.75rem] md:max-w-[62.75rem] relative">
							{% include 'components/eyebrow.twig' with {
                                'class' : "md:absolute md:top-[0.625rem] left-0",
                                'text': fields.eyebrow
                            } %}

							{% if fields.heading %}
								{% include 'components/heading.twig' with {
                                    'class': 'main-title max-w-[48.375rem]',
                                    'indent': '<span class="max-md:hidden w-[12.5rem] h-[2.5rem] shrink-0"></span>',
                                    'value': fields.heading.value, 
                                    'type': fields.heading.type != "default" ? fields.heading.type : "h3",
                                    'has_custom_style': fields.heading.has_custom_style,
                                    'style': fields.heading.style,
                                    'to_words': true
                                } %}
							{% endif %}
						</div>
					</div>

					{% if fields.items|length %}
						{# box w-full relative flex gap-[1.5rem] #}
						<div class="flex flex-col gap-[0.75rem]">
							<div class="relative box w-full">
								<div class="swiper-container">
									<div
										class="swiper-wrapper">
										{# {% for i in 0..1 %} #}
										{% for index, item in fields.items %}
											<div class="swiper-slide">
												<div class="relative z-[2] w-fit p-[1.5rem]">
													{% if item.cta %}
														{% set link_url = item.cta.url ?: "#" %}
														{% set link_title = item.cta.title %}
														{% set link_target = item.cta.target ?: "_self" %}

														<a class="flex gap-[0.75rem] items-center group" href="{{ link_url }}" target="{{ link_target }}">
															<p class="lg group-hover:underline decoration-[0.0625rem] underline-offset-[0.25rem] text-{{ item.text_theme }}">{{ link_title }}</p>
															<svg width="16" height="17" viewbox="0 0 16 17" fill="none" xmlns="http://www.w3.org/2000/svg">
																<path class="stroke-{{ item.text_theme }}" d="M8 1.83325L14.6667 8.49992L8 15.1666M0 8.49992H14.302" stroke-width="1.5" stroke-miterlimit="10"/>
															</svg>
														</a>
													{% endif %}
												</div>

												{% include 'components/image.twig' with {
                                                'image': item.image,
                                                'class': "absolute top-0 left-0 h-full w-full",
                                                'size': [655, 655],
                                            } %}

												<div class="ticker translate-x-[-120%] absolute bottom-0 left-0 h-[1.875rem] w-[16.75rem] z-[2] pointer-events-none">
													<svg class="h-full w-auto" width="268" height="30" viewbox="0 0 268 30" fill="none" xmlns="http://www.w3.org/2000/svg">
														<line x1="1.31134e-06" y1="15" x2="268" y2="15" stroke="url(#paint0_linear_6469_24838)" stroke-width="30" stroke-dasharray="3 7"/>
														<defs>
															<linearGradient id="paint0_linear_6469_24838" x1="1.39876e-06" y1="14" x2="268.005" y2="14.5023" gradientunits="userSpaceOnUse">
																<stop stop-color="#6AFF96" stop-opacity="0"/>
																<stop offset="1" stop-color="#6AFF96"/>
															</linearGradient>
														</defs>
													</svg>
												</div>
											</div>
										{% endfor %}
										{# {% endfor %} #}
									</div>
								</div>

								<div class="orb scale-0 opacity-0 absolute top-0 left-0 h-[5.25rem] w-[5.25rem] bg-[rgba(38,38,38,0.90)] rounded-[50%] overflow-hidden flex items-center justify-center text-center z-[2] pointer-events-none">
									<small class="text-white">Drag</small>
								</div>
							</div>

							<div class="lg:hidden flex shrink-0 gap-[0.75rem] max-lg:justify-between">
								<div class="arrow-left">
									<svg class="w-[1.5rem] h-[1.5rem]" width="24" height="25" viewbox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
										<path d="M15 18.76L9 12.76L15 6.76001" stroke="#262626"/>
									</svg>
								</div>

								<div class="arrow-right">
									<svg class="w-[1.5rem] h-[1.5rem]" width="24" height="25" viewbox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
										<path d="M9 6.76001L15 12.76L9 18.76" stroke="#262626"/>
									</svg>
								</div>
							</div>
						</div>
					{% endif %}

					{% include 'components/cta.twig' with {
                        'class' : 'filled blue',
                        'cta': fields.cta, 
                        'icon': true,
                    } %}
				</div>
			</div>
		</div>
	</div>

	<div class="parallax absolute ~right-[-4.5rem]/[-0.75rem] ~top-[14.75rem]/[6.375rem] pointer-events-none">
		<img class="~w-[24rem]/[32.625rem] ~h-[44.875rem]/[61rem] object-contain" src="{{ function("webp", "robot-drawing") }}" loading="lazy" alt="background graphic">
	</div>
</section>

{% endcache %}
