{# {{ function('dd', fields) }} #}
{% cache "block;" ~ post.id ~ ";" ~ block.id ~ ";" ~ post.modified_timestamp ~ ";" ~ cache_key %}

<section class="{{ block.slug }} bg-{{ fields.bg }} {{ fields.is_inverted ? "is-inverted" }}">
	{% if block.anchor %}
		<div class="section-anchor" id="{{ block.anchor ?? block.id }}"></div>
	{% endif %}

	{% set pt = fields.padding_top and fields.padding_top != "unset" ? fields.padding_top : "st-xxl" %}
	{% set pb = fields.padding_top and fields.padding_bottom != "unset" ? fields.padding_bottom : "sb-xxl" %}

	<div class="container">
		<div class="{{ pt }} {{ pb }}">
			<div class="inner flex max-md:flex-col ~gap-[3rem]/[8.625rem] items-center">
				{% if fields.image or fields.video %}
					<div class="rounded-[0.375rem] overflow-hidden relative w-full md:basis-[34.125rem] ~h-[24.25rem]/[40.5rem] md:flex-1">
						<div class="ticker translate-y-[-100%] top-0 left-0 w-[1.875rem] h-[20.25rem] z-[2] absolute">
							<svg class="w-auto h-auto" width="30" height="324" viewbox="0 0 30 324" fill="none" xmlns="http://www.w3.org/2000/svg">
								<line x1="15" y1="0.112304" x2="15" y2="323.112" stroke="url(#paint0_linear_5567_11126)" stroke-width="30" stroke-dasharray="3 7"/>
								<defs>
									<linearGradient id="paint0_linear_5567_11126" x1="16" y1="0.112304" x2="15.2705" y2="323.117" gradientunits="userSpaceOnUse">
										<stop stop-color="#6AFF96" stop-opacity="0"/>
										<stop offset="1" stop-color="#6AFF96"/>
									</linearGradient>
								</defs>
							</svg>
						</div>

						{% if fields.media_type == "image" %}
							{% if fields.image %}
								{% include 'components/image.twig' with {
                                    'image': fields.image,
                                    'class': 'object-cover h-full w-full',
                                    'size': [546, 648],
                                } %}
							{% endif %}
						{% else %}
							{% if fields.video %}
								<div class="video-container" data-video-id="{{ fields.video }}"></div>
							{% endif %}
						{% endif %}
					</div>
				{% endif %}

				<div class="flex flex-col md:flex-1 md:basis-[41.25rem] ~gap-[1.5rem]/[2.25rem] h-fit relative">
					<div class="w-full max-md:flex max-md:flex-col max-md:gap-[0.75rem] md:max-w-[62.75rem] relative pr-[2.25rem]">
						{% include 'components/eyebrow.twig' with {
                            'class' : "md:absolute md:top-[0.625rem] left-0",
                            'text': fields.eyebrow
                        } %}

						{% if fields.heading %}
							{% include 'components/heading.twig' with {
                                'class': 'main-title',
                                'indent': '<span class="max-md:hidden w-[12.5rem] h-[2.5rem] shrink-0"></span>',
                                'value': fields.heading.value, 
                                'type': fields.heading.type != "default" ? fields.heading.type : "h3",
                                'has_custom_style': fields.heading.has_custom_style,
                                'style': fields.heading.style,
                                'to_words': true
                            } %}
						{% endif %}
					</div>

					{% if fields.paragraph or fields.cta %}
						<div class="flex flex-col ~gap-[1.25rem]/[1.5rem]">
							{% if fields.paragraph %}
								<div class="rich-text">{{ fields.paragraph }}</div>
							{% endif %}

							{% include 'components/cta.twig' with {
                                'class' : 'filled blue',
                                'cta': fields.cta, 
                                'icon': true,
                            } %}
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>
</section>

{% endcache %}
