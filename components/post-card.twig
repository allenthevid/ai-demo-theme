{# components/post-card.twig #}
<article class="post-card group bg-[#F3EEDD] rounded-[16px] border border-[#031E361A] flex flex-col shadow-[0_6px_12px_0_rgba(0,0,0,0.03)] h-full transition-transform transform">
    <a href="{{ post.link }}" class="max-h-[209px]">
        <div class="post-thumbnail w-full h-[209px] overflow-hidden">
            {% if post.thumbnail %}
                <img src="{{ post.thumbnail.src }}" alt="{{ post.title }}" class="rounded-t-[16px] w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
            {% else %}
                <div class="w-full h-full bg-gray-300 flex items-center justify-center rounded-t-[16px]">
                    <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
            {% endif %}
        </div>
    </a>

    <div class="content px-[24px] py-[39.5px] flex flex-col gap-[12px] grow">
        {% if post.terms('category') %}
            <a href="{{ post.terms('category')[0].link }}" class="post-category text-[12px] uppercase tracking-wider font-bold {{ text_class }} mb-[12px] hover:text-tertiary transition-colors">
                {{ post.terms('category')[0].name }}
            </a>
        {% endif %}

        <a href="{{ post.link }}">
            <h3 class="post-title {{ text_class }} text-[20px] lg:text-[24px] font-bold leading-[130%] mb-[12px] hover:text-tertiary transition-colors">
                {{ post.title }}
            </h3>
        </a>

        {% if post.preview %}
            <div class="post-excerpt {{ text_class }} [&_p]:text-medium text-[#0000008C] leading-[135%] mb-[16px] grow">
                {{ post.preview.read_more(false)|striptags|truncate(12, true, '...') }}
            </div>
        {% endif %}

        <div class="read-more inline-flex items-center gap-[8px] {{ text_class }} text-[14px] font-medium group-hover:gap-[12px] transition-all">
            <a href="{{ post.link }}" class="post-link text-[#000000] text-medium flex">
                Read Full Article →
            </a>
        </div>
    </div>
</article>